NEWSLETTER_ENV=prod
NEWSLETTER_HTTP_ADDR=127.0.0.1:9502
NEWSLETTER_DATABASE_URL=postgres://htmlctl_newsletter_prod:<replace-password>@127.0.0.1:5432/htmlctl_newsletter_prod?sslmode=disable
NEWSLETTER_PUBLIC_BASE_URL=https://example.com
NEWSLETTER_RESEND_API_KEY=<replace-prod-resend-api-key>
# Valid sender address, for example Team <newsletter@example.com>
NEWSLETTER_RESEND_FROM=Team <newsletter@example.com>
# Random URL-safe secret, minimum 32 characters
NEWSLETTER_LINK_SECRET=<replace-prod-link-secret>
