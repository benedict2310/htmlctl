NEWSLETTER_ENV=staging
NEWSLETTER_HTTP_ADDR=127.0.0.1:9501
NEWSLETTER_DATABASE_URL=postgres://htmlctl_newsletter_staging:<replace-password>@127.0.0.1:5432/htmlctl_newsletter_staging?sslmode=disable
NEWSLETTER_PUBLIC_BASE_URL=https://staging.example.com
NEWSLETTER_RESEND_API_KEY=<replace-staging-resend-api-key>
# Valid sender address, for example Team <newsletter@example.com>
NEWSLETTER_RESEND_FROM=Team <newsletter@example.com>
# Random URL-safe secret, minimum 32 characters
NEWSLETTER_LINK_SECRET=<replace-staging-link-secret>
